#!/usr/bin/env bash
set -e

NAME="$1"
if [ -z "$NAME" ]; then
  echo "Usage: week9-add <project-name>"
  exit 1
fi

# Tạo project mới
cargo init "$NAME"

# Thêm vào workspace (tự xử lý đúng thứ tự)
WORKSPACE="Cargo.toml"
if grep -q "^\[workspace\]" "$WORKSPACE"; then
  # Xoá dòng members cũ nếu có
  sed -i "/^\[workspace\]/,/^\[.*\]/{
    /members = \[/,/\]/{
      /\]/a\\
\\
# --- auto-managed projects ---
    }
  }" "$WORKSPACE" 2>/dev/null || true

  # Kiểm tra đã có trong members chưa
  if ! grep -q "\"$NAME\"" "$WORKSPACE"; then
    # Thêm vào cuối block members
    sed -i "/members = \[/,/\]/ {
      /\]/i\    \"$NAME\",
    }" "$WORKSPACE"
    echo "Added '$NAME' to workspace"
  else
    echo "'$NAME' already in workspace"
  fi
fi

# Git add + commit
git add "$NAME/"
git add "$WORKSPACE"
git add Cargo.lock 2>/dev/null || true
git add .gitignore 2>/dev/null || true
git commit -m "chore: add project '$NAME'

Generated by week9-add script
Co-Authored-By: Claude <noreply@anthropic.com>" --quiet

echo ""
echo "Done! Run with:"
echo "  cargo run -p $NAME"
